# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/cefiishop
SPRING_DATASOURCE_USERNAME=cefiishop_user
SPRING_DATASOURCE_PASSWORD=cefiishop_pass
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# MongoDB Configuration
SPRING_DATA_MONGODB_URI=mongodb://mongo:27017/cefiishop
SPRING_AI_VECTORSTORE_MONGODB_URI=mongodb://mongo:27017/cefiishop

# IA/API Configuration
OPENAI_API_KEY=your_openai_key_here
OLLAMA_HOST=http://ollama:11434

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api

# MongoDB
MONGODB_ATLAS_URI=mongodb://mongo:27017/cefiishop

# Docker Registry (for CI/CD)
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your_github_username
DOCKER_TOKEN=your_github_token
